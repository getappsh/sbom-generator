# Environment — sbom-generator

# ── Server ──────────────────────────────────────────────────────────────────
SBOM_GENERATOR_HTTP_PORT=3008

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=get_app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<your-password>
MIGRATION_RUN=true

# ── MinIO / S3 ────────────────────────────────────────────────────────────────
S3_ENDPOINT_INTERNAL=http://localhost:9090
ACCESS_KEY_ID=admin-minio
SECRET_ACCESS_KEY=password-minio
MINIO_USE_SSL=false
SBOM_BUCKET_NAME=sbom-reports
DOWNLOAD_URL_EXPIRE=3600
UPLOAD_URL_EXPIRE=3600

# ── Syft ──────────────────────────────────────────────────────────────────────
# Set to 'true' in local dev to run Syft via Docker instead of a binary
USE_DOCKER_FOR_SYFT=false
SYFT_VERSION=latest

# ── Concurrency ───────────────────────────────────────────────────────────────
SCAN_MAX_CONCURRENT=3

# ── Microservice transport (KAFKA | SOCKET) ───────────────────────────────────
MICRO_SERVICE_TYPE=KAFKA
KAFKA_BROKER_URL=127.0.0.1:9092
CONSUME_CONCURRENT=100

# Socket fallback (MICRO_SERVICE_TYPE=SOCKET)
# SBOM_GENERATOR_HOST=localhost
# SBOM_GENERATOR_PORT=3009  # TCP microservice port (must differ from SBOM_GENERATOR_HTTP_PORT)

# ── Logging ───────────────────────────────────────────────────────────────────
LOGGER_FORMAT=JSON
