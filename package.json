{
  "name": "sbom-generator",
  "version": "0.0.1",
  "description": "SBOM generation microservice wrapping Syft",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start:no-mig": "nest start",
    "start:dev:no-mig": "nest start --watch",
    "start": "npm run migration:run && nest start",
    "start:dev": "npm run migration:run && nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/sbom-generator/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "migration:create": "typeorm-ts-node-esm migration:create libs/common/src/database/migration/%npm_config_name%",
    "migration:show": "typeorm-ts-node-esm -d libs/common/src/database/config/ormconfig.ts migration:show",
    "migration:generate": "typeorm-ts-node-esm -d libs/common/src/database/config/ormconfig.ts migration:generate libs/common/src/database/migration/%npm_config_name%",
    "migration:run": "typeorm-ts-node-esm -d libs/common/src/database/config/ormconfig.ts migration:run",
    "migration:revert": "typeorm-ts-node-esm -d libs/common/src/database/config/ormconfig.ts migration:revert"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.296.0",
    "@turf/turf": "^6.5.0",
    "@aws-sdk/lib-storage": "^3.412.0",
    "@aws-sdk/s3-request-presigner": "^3.296.0",
    "@nestjs/common": "^9.3.9",
    "@nestjs/config": "^2.3.1",
    "@nestjs/core": "^9.3.9",
    "@nestjs/microservices": "^9.3.9",
    "@nestjs/platform-express": "^9.3.9",
    "@nestjs/swagger": "^6.2.1",
    "@nestjs/typeorm": "^10.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "dotenv": "^16.0.3",
    "kafkajs": "git://github.com/getappsh/kafkajs/tree/bug#17f3c7f0c1b9509e4071ad6a5a77e922362d19c0",
    "minio": "^8.0.1",
    "nanoid": "3.3.7",
    "nestjs-cls": "^4.2.0",
    "nestjs-elastic-apm": "^1.3.0",
    "nestjs-pino": "^4.0.0",
    "pg": "^8.9.0",
    "pino": "^8.21.0",
    "pino-http": "^9.0.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "typeorm": "^0.3.17",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^9.2.0",
    "@nestjs/schematics": "^9.0.4",
    "@nestjs/testing": "^9.3.9",
    "@types/express": "^4.17.17",
    "@types/multer": "^1.4.7",
    "webpack": "^5.82.1",
    "@types/jest": "29.2.4",
    "@types/node": "18.11.18",
    "@types/uuid": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^5.52.0",
    "@typescript-eslint/parser": "^5.52.0",
    "eslint": "^8.34.0",
    "eslint-config-prettier": "^8.6.0",
    "eslint-plugin-prettier": "^4.2.1",
    "jest": "29.3.1",
    "prettier": "^2.8.4",
    "source-map-support": "^0.5.20",
    "supertest": "^6.3.3",
    "ts-jest": "29.0.3",
    "ts-loader": "^9.4.2",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "4.1.1",
    "typescript": "^4.7.4"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "^@app/common(|/.*)$": "<rootDir>/libs/common/src/$1",
      "^@app/root(|/.*)$": "<rootDir>/apps/$1"
    }
  }
}
